<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="NutriPlan">
<title>NutriPlan</title>
<style>
:root {
  --bg:        #111113;
  --card:      #1F1F22;
  --elevated:  #2A2A2E;
  --gold:      #C9AB6E;
  --bronze:    #8B7255;
  --green:     #6A9E72;
  --red:       #BF4D40;
  --text:      #F2EDE4;
  --muted:     #999080;
  --divider:   #333336;
  --radius:    14px;
  --tab-h:     calc(60px + env(safe-area-inset-bottom));
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, sans-serif; overscroll-behavior: none; }
body { overflow: hidden; }

/* ── Layout ── */
#app { display: flex; flex-direction: column; height: 100vh; height: 100dvh; }
#content { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; padding-bottom: var(--tab-h); }
.view { display: none; padding: 16px; animation: fadeIn .18s ease; }
.view.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

/* ── Tab Bar ── */
#tabbar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: var(--tab-h);
  background: #18181B;
  border-top: 1px solid var(--divider);
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}
.tab-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 3px; background: none; border: none; color: var(--muted); font-size: 10px;
  cursor: pointer; padding: 6px 0; transition: color .15s;
}
.tab-btn.active { color: var(--gold); }
.tab-btn svg { width: 22px; height: 22px; stroke-width: 1.8; }

/* ── Cards ── */
.card { background: var(--card); border-radius: var(--radius); padding: 16px; margin-bottom: 14px; }
.card-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 14px; }
.elevated { background: var(--elevated); border-radius: 10px; }

/* ── Buttons ── */
.btn-gold {
  width: 100%; padding: 14px; background: var(--gold); color: #111;
  border: none; border-radius: 14px; font-size: 16px; font-weight: 600;
  cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
}
.btn-gold:disabled { opacity: .45; }
.btn-ghost { background: none; border: none; color: var(--gold); font-size: 14px; cursor: pointer; }
.btn-danger { background: none; border: none; color: var(--red); font-size: 14px; cursor: pointer; }

/* ── Form Controls ── */
input, textarea, select {
  width: 100%; background: var(--elevated); border: none; border-radius: 10px;
  color: var(--text); font-size: 15px; padding: 11px 13px; font-family: inherit;
  outline: none; -webkit-appearance: none;
}
textarea { resize: vertical; min-height: 90px; }
select option { background: var(--elevated); }
.field { margin-bottom: 14px; }
.field label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 5px; }
.field-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; }
.field-row + .field-row { border-top: 1px solid var(--divider); }

/* ── Slider ── */
input[type=range] {
  padding: 0; background: none; height: 28px;
  -webkit-appearance: none; appearance: none;
}
input[type=range]::-webkit-slider-runnable-track {
  height: 4px; background: var(--divider); border-radius: 2px;
}
input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none; width: 22px; height: 22px;
  background: var(--gold); border-radius: 50%; margin-top: -9px;
  box-shadow: 0 1px 4px rgba(0,0,0,.4);
}

/* ── Segmented ── */
.seg { display: flex; background: var(--elevated); border-radius: 10px; padding: 3px; gap: 2px; }
.seg-btn {
  flex: 1; padding: 7px; border: none; border-radius: 8px; background: none;
  color: var(--muted); font-size: 14px; font-weight: 500; cursor: pointer; transition: all .15s;
}
.seg-btn.active { background: var(--gold); color: #111; font-weight: 600; }

/* ── Tags ── */
.tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 10px; }
.tag {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 20px; font-size: 13px;
  border: 1px solid; cursor: default;
}
.tag.bronze { color: var(--text); border-color: rgba(139,114,85,.4); background: rgba(139,114,85,.12); }
.tag.red    { color: var(--text); border-color: rgba(191,77,64,.4);  background: rgba(191,77,64,.12); }
.tag-x { background: none; border: none; color: inherit; font-size: 12px; cursor: pointer; padding: 0; }
.tag-input-row { display: flex; gap: 8px; }
.tag-input-row input { flex: 1; }
.tag-add { background: none; border: none; color: var(--gold); font-size: 22px; cursor: pointer; padding: 0 4px; }

/* ── Progress Bar ── */
.progress-track { background: var(--divider); border-radius: 4px; height: 6px; overflow: hidden; }
.progress-fill  { height: 100%; border-radius: 4px; background: var(--gold); transition: width .4s ease; }
.progress-fill.green { background: var(--green); }

/* ── Day Card ── */
.day-card { background: var(--card); border-radius: var(--radius); margin-bottom: 12px; overflow: hidden; cursor: pointer; }
.day-card-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 14px 10px; }
.day-num { font-size: 16px; font-weight: 700; }
.day-kcal { font-size: 14px; font-weight: 600; }
.day-kcal.green { color: var(--green); }
.day-kcal.gold  { color: var(--gold); }
.day-kcal.red   { color: var(--red); }
.cal-bar { margin: 0 14px 10px; }
.meal-row { display: flex; align-items: center; gap: 10px; padding: 9px 14px; }
.meal-row + .meal-row { border-top: 1px solid var(--divider); }
.meal-icon { font-size: 16px; width: 20px; text-align: center; }
.meal-info { flex: 1; min-width: 0; }
.meal-type { font-size: 11px; color: var(--muted); }
.meal-name { font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.meal-kcal { font-size: 12px; color: var(--muted); white-space: nowrap; }
.day-hint { text-align: right; padding: 6px 14px 10px; font-size: 11px; color: var(--muted); }

/* ── Recipe Card ── */
.recipe-card { display: flex; align-items: center; gap: 12px; padding: 13px; background: var(--card); border-radius: 12px; margin-bottom: 10px; cursor: pointer; }
.recipe-icon { width: 46px; height: 46px; border-radius: 23px; background: rgba(201,171,110,.14); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.recipe-name { font-size: 15px; font-weight: 500; }
.recipe-meta { font-size: 12px; color: var(--muted); margin-top: 2px; }

/* ── Shopping Row ── */
.shop-row { display: flex; align-items: center; gap: 12px; padding: 11px 14px; cursor: pointer; }
.shop-row + .shop-row { border-top: 1px solid var(--divider); }
.check-circle {
  width: 25px; height: 25px; border-radius: 50%; border: 2px solid var(--divider);
  flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 13px; transition: all .2s;
}
.check-circle.done { border-color: var(--green); color: var(--green); }
.shop-name { flex: 1; font-size: 14px; transition: all .2s; }
.shop-name.done { color: var(--muted); text-decoration: line-through; }
.shop-days { font-size: 11px; color: var(--muted); }
.section-faded { opacity: .6; }

/* ── Stepper ── */
.stepper { display: flex; align-items: center; gap: 10px; }
.stepper-btn { background: none; border: none; color: var(--gold); font-size: 22px; cursor: pointer; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; }
.stepper-val { font-size: 18px; font-weight: 700; color: var(--gold); min-width: 32px; text-align: center; }

/* ── Modal ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 200;
  display: flex; align-items: flex-end; opacity: 0; pointer-events: none; transition: opacity .2s;
}
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal {
  background: var(--bg); width: 100%; border-radius: 20px 20px 0 0;
  max-height: 92vh; display: flex; flex-direction: column;
  transform: translateY(40px); transition: transform .25s ease;
  padding-bottom: env(safe-area-inset-bottom);
}
.modal-overlay.open .modal { transform: translateY(0); }
.modal-handle { width: 36px; height: 4px; background: var(--divider); border-radius: 2px; margin: 12px auto 0; }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px 10px; }
.modal-title { font-size: 17px; font-weight: 700; }
.modal-close { background: none; border: none; color: var(--muted); font-size: 15px; cursor: pointer; }
.modal-body { overflow-y: auto; -webkit-overflow-scrolling: touch; padding: 0 16px 20px; flex: 1; }

/* ── Step Row ── */
.step-row { display: flex; gap: 12px; margin-bottom: 16px; cursor: pointer; }
.step-num { width: 28px; height: 28px; border-radius: 50%; background: var(--elevated); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: var(--muted); flex-shrink: 0; transition: all .2s; }
.step-num.active { background: var(--gold); color: #111; }
.step-text { font-size: 14px; color: var(--muted); line-height: 1.55; transition: color .2s; padding-top: 4px; }
.step-text.active { color: var(--text); }

/* ── Misc ── */
.divider { height: 1px; background: var(--divider); margin: 10px 0; }
.badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 8px; font-size: 12px; }
.badge.gold { background: rgba(201,171,110,.15); color: var(--gold); }
.badge.green { background: rgba(106,158,114,.15); color: var(--green); }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 50px 30px; text-align: center; gap: 12px; }
.empty-icon { font-size: 52px; opacity: .5; }
.empty-title { font-size: 18px; font-weight: 600; }
.empty-text { font-size: 14px; color: var(--muted); line-height: 1.5; }
.cat-label { font-size: 12px; font-weight: 600; color: var(--muted); margin: 16px 0 8px; display: flex; align-items: center; gap: 6px; }
.info-box { background: rgba(106,158,114,.08); border-radius: 10px; padding: 11px 13px; display: flex; gap: 8px; align-items: flex-start; }
.info-box span { font-size: 13px; color: var(--muted); line-height: 1.5; font-style: italic; }
.spinner { width: 22px; height: 22px; border: 2px solid rgba(201,171,110,.3); border-top-color: var(--gold); border-radius: 50%; animation: spin .7s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.model-radio { display: flex; align-items: center; gap: 10px; padding: 11px 0; cursor: pointer; }
.model-radio + .model-radio { border-top: 1px solid var(--divider); }
.radio-circle { width: 20px; height: 20px; border-radius: 50%; border: 2px solid var(--divider); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.radio-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); display: none; }
.model-radio.selected .radio-circle { border-color: var(--gold); }
.model-radio.selected .radio-dot { display: block; }
.model-id { font-size: 11px; color: var(--muted); }
.token-row { display: flex; gap: 8px; align-items: center; }
.token-row input { flex: 1; font-family: monospace; font-size: 13px; }
.eye-btn { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 18px; padding: 0 4px; }
</style>
</head>
<body>
<div id="app">
  <div id="content">
    <!-- PLAN TAB -->
    <div class="view active" id="view-plan">
      <div id="plan-content"></div>
    </div>
    <!-- REZEPTE TAB -->
    <div class="view" id="view-recipes">
      <div id="recipes-content"></div>
    </div>
    <!-- EINKAUF TAB -->
    <div class="view" id="view-shopping">
      <div id="shopping-content"></div>
    </div>
    <!-- EINSTELLUNGEN TAB -->
    <div class="view" id="view-settings">
      <div id="settings-content"></div>
    </div>
  </div>

  <!-- TAB BAR -->
  <div id="tabbar">
    <button class="tab-btn active" onclick="switchTab('plan')" id="tab-plan">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Plan
    </button>
    <button class="tab-btn" onclick="switchTab('recipes')" id="tab-recipes">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      Rezepte
    </button>
    <button class="tab-btn" onclick="switchTab('shopping')" id="tab-shopping">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      Einkauf
    </button>
    <button class="tab-btn" onclick="switchTab('settings')" id="tab-settings">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Einstellungen
    </button>
  </div>
</div>

<!-- MODALS -->
<div class="modal-overlay" id="modal-day" onclick="closeModal('modal-day')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title" id="modal-day-title">Tag 1</span>
      <button class="modal-close" onclick="closeModal('modal-day')">Fertig</button>
    </div>
    <div class="modal-body" id="modal-day-body"></div>
  </div>
</div>

<div class="modal-overlay" id="modal-cook" onclick="closeModal('modal-cook')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title">Kochen</span>
      <button class="modal-close" onclick="closeModal('modal-cook')">Fertig</button>
    </div>
    <div class="modal-body" id="modal-cook-body"></div>
  </div>
</div>

<div class="modal-overlay" id="modal-recipe-detail" onclick="closeModal('modal-recipe-detail')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title">Rezept</span>
      <button class="modal-close" onclick="closeModal('modal-recipe-detail')">Fertig</button>
    </div>
    <div class="modal-body" id="modal-recipe-body"></div>
  </div>
</div>

<div class="modal-overlay" id="modal-add-recipe" onclick="closeModal('modal-add-recipe')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title">Rezept hinzufügen</span>
      <button class="modal-close" onclick="closeModal('modal-add-recipe')">✕</button>
    </div>
    <div class="modal-body">
      <div class="field"><label>Rezeptname *</label><input id="r-name" placeholder="z.B. Haferbrei mit Beeren"></div>
      <div class="field"><label>Kategorie</label>
        <select id="r-cat">
          <option value="breakfast">Frühstück</option>
          <option value="lunch">Mittagessen</option>
          <option value="dinner">Abendessen</option>
          <option value="snack">Snack</option>
          <option value="any">Flexibel</option>
        </select>
      </div>
      <div class="field-row"><span>Kalorien (gesamt)</span>
        <div class="stepper"><button class="stepper-btn" onclick="stepRecipe('calories',-50)">−</button><span class="stepper-val" id="r-cal-val">400</span><button class="stepper-btn" onclick="stepRecipe('calories',50)">+</button></div>
      </div>
      <div class="field-row"><span>Portionen</span>
        <div class="stepper"><button class="stepper-btn" onclick="stepRecipe('servings',-1)">−</button><span class="stepper-val" id="r-srv-val">1</span><button class="stepper-btn" onclick="stepRecipe('servings',1)">+</button></div>
      </div>
      <div class="field-row"><span>Zubereitungszeit (Min.)</span>
        <div class="stepper"><button class="stepper-btn" onclick="stepRecipe('prep',-5)">−</button><span class="stepper-val" id="r-prep-val">30</span><button class="stepper-btn" onclick="stepRecipe('prep',5)">+</button></div>
      </div>
      <div class="field" style="margin-top:14px"><label>Zutaten (eine pro Zeile) *</label><textarea id="r-ingredients" placeholder="80g Haferflocken&#10;250ml Hafermilch&#10;100g Heidelbeeren"></textarea></div>
      <div class="field"><label>Zubereitung</label><textarea id="r-instructions" placeholder="Schritt 1: ...&#10;Schritt 2: ..."></textarea></div>
      <div class="field"><label>Notizen (optional)</label><input id="r-notes" placeholder="Tipps, Variationen..."></div>
      <button class="btn-gold" onclick="saveRecipe()" style="margin-top:8px">Rezept speichern</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-shopping-filter" onclick="closeModal('modal-shopping-filter')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title">Einkaufszettel</span>
      <button class="modal-close" onclick="closeModal('modal-shopping-filter')">✕</button>
    </div>
    <div class="modal-body" id="modal-shopping-filter-body"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
const MODELS = [
  { id: 'meta-llama/Llama-3.1-8B-Instruct',   name: 'Llama 3.1 8B (Empfohlen)' },
  { id: 'Qwen/Qwen2.5-7B-Instruct',           name: 'Qwen 2.5 7B' },
  { id: 'mistralai/Mistral-7B-Instruct-v0.3', name: 'Mistral 7B' },
  { id: 'microsoft/Phi-3.5-mini-instruct',     name: 'Phi-3.5 Mini (Schnell)' }
];

const MEAL_META = {
  breakfast: { label: 'Frühstück',   icon: '🌅' },
  lunch:     { label: 'Mittagessen', icon: '☀️' },
  dinner:    { label: 'Abendessen',  icon: '🌙' },
  snack:     { label: 'Snack',       icon: '🍃' },
  any:       { label: 'Flexibel',    icon: '🍴' }
};

let state = {
  settings: {
    calories: 2000, mealsPerDay: 3, diet: 'Alles',
    hfModel: 'meta-llama/Llama-3.1-8B-Instruct',
    token: '', disliked: [], avoided: []
  },
  recipes: [],
  plan: null,
  shopping: [],
  numberOfDays: 7
};

// Temp state for new recipe form
let _recipeForm = { calories: 400, servings: 1, prep: 30 };
// Temp state for cooking modal ingredient checks
let _cookChecked = {};

function save() {
  try { localStorage.setItem('nutriplan', JSON.stringify(state)); } catch(e) {}
}

function load() {
  try {
    const d = localStorage.getItem('nutriplan');
    if (d) state = { ...state, ...JSON.parse(d) };
  } catch(e) {}
}

// ═══════════════════════════════════════════════
// TAB SWITCHING
// ═══════════════════════════════════════════════
let currentTab = 'plan';
function switchTab(tab) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('view-' + tab).classList.add('active');
  document.getElementById('tab-' + tab).classList.add('active');
  currentTab = tab;
  renderTab(tab);
}
function renderTab(tab) {
  if (tab === 'plan')     renderPlan();
  if (tab === 'recipes')  renderRecipes();
  if (tab === 'shopping') renderShopping();
  if (tab === 'settings') renderSettings();
}

// ═══════════════════════════════════════════════
// MODALS
// ═══════════════════════════════════════════════
function openModal(id) {
  const el = document.getElementById(id);
  el.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = '';
}

// ═══════════════════════════════════════════════
// PLAN VIEW
// ═══════════════════════════════════════════════
let isGenerating = false;

function renderPlan() {
  const c = document.getElementById('plan-content');
  const tokenOk = !!state.settings.token.trim();
  const modelName = MODELS.find(m => m.id === state.settings.hfModel)?.name || state.settings.hfModel;

  let html = `
  <div class="card" style="border: 1px solid rgba(201,171,110,.2)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
      <div>
        <div style="font-size:16px;font-weight:600">Neuer Essensplan</div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px">⚙️ ${modelName}</div>
      </div>
      <div style="font-size:24px">✨</div>
    </div>
    <div class="divider"></div>
    <div class="field-row" style="margin:10px 0">
      <span style="font-size:15px">Anzahl Tage</span>
      <div class="stepper">
        <button class="stepper-btn" onclick="changeDays(-1)">−</button>
        <span class="stepper-val" id="days-val">${state.numberOfDays}</span>
        <button class="stepper-btn" onclick="changeDays(1)">+</button>
      </div>
    </div>
    <button class="btn-gold" id="gen-btn" onclick="generatePlan()" ${!tokenOk || isGenerating ? 'disabled' : ''}>
      ${isGenerating
        ? '<div class="spinner"></div><span>Wird erstellt…</span>'
        : '✨ Plan erstellen'}
    </button>
    ${!tokenOk ? '<p style="font-size:12px;color:var(--bronze);margin-top:10px;text-align:center">⚠️ Hugging Face Token in Einstellungen erforderlich</p>' : ''}
  </div>`;

  if (isGenerating) {
    html += `<div class="card" style="display:flex;gap:14px;align-items:center">
      <div class="spinner"></div>
      <div>
        <div style="font-size:14px;font-weight:500">KI erstellt deinen Plan…</div>
        <div style="font-size:12px;color:var(--muted);margin-top:3px">Saisonalität, Nährstoffe & Abwechslung werden berücksichtigt</div>
      </div>
    </div>`;
  }

  if (state.plan) {
    html += `<div class="card" style="display:flex;align-items:center;justify-content:space-between">
      <div>
        <div style="font-size:16px;font-weight:700">${state.plan.days.length}-Tage-Plan</div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px">Erstellt ${new Date(state.plan.generatedAt).toLocaleString('de-DE',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}</div>
      </div>
      <div style="font-size:24px">📅</div>
    </div>`;
    for (const day of state.plan.days) {
      html += renderDayCard(day);
    }
  } else if (!isGenerating) {
    html += `<div class="empty-state">
      <div class="empty-icon">📅</div>
      <div class="empty-title">Noch kein Plan erstellt</div>
      <div class="empty-text">Wähle die Anzahl Tage und tippe auf „Plan erstellen".</div>
    </div>`;
  }

  c.innerHTML = html;
}

function renderDayCard(day) {
  const ratio = day.totalCalories / state.settings.calories;
  const cls = ratio > 1.12 ? 'red' : ratio < 0.88 ? 'gold' : 'green';
  const barPct = Math.min(ratio * 100, 100).toFixed(1);
  const barColor = cls === 'green' ? 'var(--green)' : cls === 'gold' ? 'var(--gold)' : 'var(--red)';

  let meals = day.meals.map(m => `
    <div class="meal-row">
      <span class="meal-icon">${MEAL_META[m.type]?.icon || '🍴'}</span>
      <div class="meal-info">
        <div class="meal-type">${MEAL_META[m.type]?.label || m.type}${m.isUserRecipe ? ' ⭐' : ''}</div>
        <div class="meal-name">${m.name}</div>
      </div>
      <span class="meal-kcal">${m.calories} kcal</span>
    </div>`).join('');

  return `<div class="day-card" onclick="openDayModal(${day.dayNumber})">
    <div class="day-card-header">
      <span class="day-num">Tag ${day.dayNumber}</span>
      <span class="day-kcal ${cls}">🔥 ${day.totalCalories} kcal</span>
    </div>
    <div class="cal-bar">
      <div class="progress-track"><div class="progress-fill" style="width:${barPct}%;background:${barColor}"></div></div>
    </div>
    ${meals}
    <div class="day-hint">Tippen für Details ›</div>
  </div>`;
}

function changeDays(delta) {
  state.numberOfDays = Math.max(1, Math.min(14, state.numberOfDays + delta));
  save();
  const el = document.getElementById('days-val');
  if (el) el.textContent = state.numberOfDays;
}

// ═══════════════════════════════════════════════
// DAY DETAIL MODAL
// ═══════════════════════════════════════════════
function openDayModal(dayNum) {
  const day = state.plan?.days.find(d => d.dayNumber === dayNum);
  if (!day) return;

  document.getElementById('modal-day-title').textContent = `Tag ${dayNum} · ${day.totalCalories} kcal`;

  let html = `<div style="margin-bottom:14px">
    <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--muted);margin-bottom:6px">
      <span>${day.meals.length} Mahlzeiten</span><span>${day.totalCalories} kcal</span>
    </div>
    <div class="progress-track"><div class="progress-fill green" style="width:${Math.min(day.totalCalories/state.settings.calories*100,100).toFixed(1)}%"></div></div>
  </div>`;

  for (const meal of day.meals) {
    const recipe = state.recipes.find(r => r.id === meal.linkedRecipeId);
    html += `<div class="card" style="margin-bottom:12px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
        <span style="font-size:12px;color:var(--gold);font-weight:600">${MEAL_META[meal.type]?.icon} ${MEAL_META[meal.type]?.label}</span>
        <span class="badge gold">${meal.calories} kcal</span>
      </div>
      <div style="font-size:17px;font-weight:700;margin-bottom:6px">${meal.name}</div>
      <div style="font-size:13px;color:var(--muted);margin-bottom:10px;line-height:1.5">${meal.description}</div>
      ${meal.ingredients.length ? `<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px">
        ${meal.ingredients.slice(0,6).map(i => `<span style="font-size:12px;padding:3px 8px;background:var(--elevated);border-radius:7px">${i}</span>`).join('')}
        ${meal.ingredients.length > 6 ? `<span style="font-size:12px;color:var(--muted)">+${meal.ingredients.length-6} mehr</span>` : ''}
      </div>` : ''}
      ${meal.nutritionHighlights ? `<div class="info-box" style="margin-bottom:10px"><span>🌿 ${meal.nutritionHighlights}</span></div>` : ''}
      ${recipe ? `<div style="font-size:12px;color:var(--gold);margin-bottom:10px">⭐ Eigenes Rezept: ${recipe.name}</div>` : ''}
      <button class="btn-gold" onclick="openCookModal(${dayNum}, '${meal.id}')">🍳 Jetzt kochen</button>
    </div>`;
  }

  document.getElementById('modal-day-body').innerHTML = html;
  openModal('modal-day');
}

// ═══════════════════════════════════════════════
// COOKING MODAL
// ═══════════════════════════════════════════════
function openCookModal(dayNum, mealId) {
  const day = state.plan?.days.find(d => d.dayNumber === dayNum);
  const meal = day?.meals.find(m => m.id === mealId);
  if (!meal) return;

  const recipe = state.recipes.find(r => r.id === meal.linkedRecipeId);
  const ingredients = (recipe?.ingredients?.length ? recipe.ingredients : meal.ingredients) || [];
  const instructions = recipe?.instructions || '';
  const steps = instructions.split('\n').map(s => s.trim()).filter(Boolean);

  _cookChecked = {};

  let html = `
  <div class="card" style="margin-bottom:14px">
    <div style="display:flex;align-items:center;gap:12px">
      <div style="width:48px;height:48px;border-radius:24px;background:rgba(201,171,110,.14);display:flex;align-items:center;justify-content:center;font-size:22px">${MEAL_META[meal.type]?.icon}</div>
      <div>
        <div style="font-size:12px;color:var(--muted)">${MEAL_META[meal.type]?.label}</div>
        <div style="font-size:17px;font-weight:700">${meal.name}</div>
        <div style="font-size:12px;color:var(--gold);margin-top:2px">🔥 ${meal.calories} kcal${recipe ? ` · ⏱ ${recipe.prepTimeMinutes} Min.` : ''}</div>
      </div>
    </div>
  </div>`;

  if (ingredients.length) {
    html += `<div class="card" style="margin-bottom:14px">
      <div class="card-title">Zutaten abhaken</div>
      <div id="cook-ingredients">`;
    ingredients.forEach((ing, i) => {
      html += `<div class="shop-row" onclick="toggleCookIngredient(${i})" id="cook-ing-${i}">
        <div class="check-circle" id="cook-check-${i}"></div>
        <span class="shop-name" id="cook-name-${i}">${ing}</span>
      </div>`;
    });
    html += `</div>
      <div style="margin-top:12px">
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:5px">
          <span id="cook-prog-txt">0/${ingredients.length} bereit</span>
        </div>
        <div class="progress-track"><div class="progress-fill green" id="cook-prog-bar" style="width:0%"></div></div>
      </div>
    </div>`;
  }

  if (steps.length) {
    html += `<div class="card" style="margin-bottom:14px"><div class="card-title">Zubereitung</div>`;
    steps.forEach((step, i) => {
      html += `<div class="step-row" onclick="toggleStep(${i})">
        <div class="step-num ${i===0?'active':''}" id="step-num-${i}">${i+1}</div>
        <div class="step-text ${i===0?'active':''}" id="step-txt-${i}">${step}</div>
      </div>`;
    });
    html += `</div>`;
  } else if (meal.description) {
    html += `<div class="card" style="margin-bottom:14px">
      <div class="card-title">Hinweis</div>
      <p style="font-size:14px;color:var(--muted);line-height:1.6">${meal.description}</p>
    </div>`;
  }

  if (meal.nutritionHighlights) {
    html += `<div class="info-box" style="margin-bottom:14px"><span>🌿 ${meal.nutritionHighlights}</span></div>`;
  }

  // Store ingredient count for updates
  html += `<script>window._cookIngTotal = ${ingredients.length};<\/script>`;

  document.getElementById('modal-cook-body').innerHTML = html;
  closeModal('modal-day');
  openModal('modal-cook');
}

function toggleCookIngredient(i) {
  _cookChecked[i] = !_cookChecked[i];
  const check = document.getElementById('cook-check-' + i);
  const name  = document.getElementById('cook-name-' + i);
  if (_cookChecked[i]) {
    check.classList.add('done'); check.textContent = '✓';
    name.classList.add('done');
  } else {
    check.classList.remove('done'); check.textContent = '';
    name.classList.remove('done');
  }
  const total = window._cookIngTotal || 0;
  const done = Object.values(_cookChecked).filter(Boolean).length;
  const pct = total ? (done / total * 100).toFixed(1) : 0;
  const progBar = document.getElementById('cook-prog-bar');
  const progTxt = document.getElementById('cook-prog-txt');
  if (progBar) progBar.style.width = pct + '%';
  if (progTxt) progTxt.textContent = `${done}/${total} bereit`;
}

function toggleStep(i) {
  document.querySelectorAll('.step-num').forEach((el, j) => {
    el.classList.toggle('active', j === i);
    document.getElementById('step-txt-' + j)?.classList.toggle('active', j === i);
  });
}
</script>

<script>
// ═══════════════════════════════════════════════
// RECIPES VIEW
// ═══════════════════════════════════════════════
function renderRecipes() {
  const c = document.getElementById('recipes-content');
  if (!state.recipes.length) {
    c.innerHTML = `<div style="display:flex;justify-content:flex-end;margin-bottom:12px">
      <button class="btn-gold" style="width:auto;padding:10px 20px" onclick="openAddRecipe()">+ Rezept</button>
    </div>
    <div class="empty-state">
      <div class="empty-icon">📖</div>
      <div class="empty-title">Noch keine Rezepte</div>
      <div class="empty-text">Füge deine Lieblingsrezepte hinzu, damit die KI sie in den Plan einbaut.</div>
    </div>`;
    return;
  }

  const groups = {};
  for (const r of state.recipes) {
    const cat = r.category || 'any';
    if (!groups[cat]) groups[cat] = [];
    groups[cat].push(r);
  }

  let html = `<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
    <div style="font-size:22px;font-weight:700">Meine Rezepte</div>
    <button class="btn-gold" style="width:auto;padding:10px 18px" onclick="openAddRecipe()">+ Neu</button>
  </div>`;

  for (const [cat, recipes] of Object.entries(groups)) {
    const m = MEAL_META[cat] || MEAL_META.any;
    html += `<div class="cat-label">${m.icon} ${m.label}</div>`;
    for (const r of recipes) {
      html += `<div class="recipe-card" onclick="openRecipeDetail('${r.id}')">
        <div class="recipe-icon">${m.icon}</div>
        <div>
          <div class="recipe-name">${r.name}</div>
          <div class="recipe-meta">🔥 ${Math.round(r.calories/(r.servings||1))} kcal · ⏱ ${r.prepTimeMinutes} Min.</div>
        </div>
        <svg style="margin-left:auto;flex-shrink:0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </div>`;
    }
  }
  c.innerHTML = html;
}

function openAddRecipe() {
  _recipeForm = { calories: 400, servings: 1, prep: 30 };
  document.getElementById('r-name').value = '';
  document.getElementById('r-cat').value = 'any';
  document.getElementById('r-ingredients').value = '';
  document.getElementById('r-instructions').value = '';
  document.getElementById('r-notes').value = '';
  document.getElementById('r-cal-val').textContent = '400';
  document.getElementById('r-srv-val').textContent = '1';
  document.getElementById('r-prep-val').textContent = '30';
  openModal('modal-add-recipe');
}

function stepRecipe(field, delta) {
  const limits = { calories: [50,3000,50], servings: [1,10,1], prep: [5,300,5] };
  const ids = { calories: 'r-cal-val', servings: 'r-srv-val', prep: 'r-prep-val' };
  const [min, max] = limits[field];
  _recipeForm[field] = Math.max(min, Math.min(max, _recipeForm[field] + delta));
  document.getElementById(ids[field]).textContent = _recipeForm[field];
}

function saveRecipe() {
  const name = document.getElementById('r-name').value.trim();
  const ingredientText = document.getElementById('r-ingredients').value.trim();
  if (!name || !ingredientText) { alert('Bitte Name und Zutaten ausfüllen.'); return; }
  const recipe = {
    id: crypto.randomUUID(),
    name,
    category: document.getElementById('r-cat').value,
    calories: _recipeForm.calories,
    servings: _recipeForm.servings,
    prepTimeMinutes: _recipeForm.prep,
    ingredients: ingredientText.split('\n').map(s=>s.trim()).filter(Boolean),
    instructions: document.getElementById('r-instructions').value.trim(),
    notes: document.getElementById('r-notes').value.trim(),
    createdAt: new Date().toISOString()
  };
  state.recipes.push(recipe);
  save();
  closeModal('modal-add-recipe');
  renderRecipes();
}

function openRecipeDetail(id) {
  const r = state.recipes.find(x => x.id === id);
  if (!r) return;
  const m = MEAL_META[r.category] || MEAL_META.any;
  const kcalPerServing = Math.round(r.calories / (r.servings || 1));
  let html = `
  <div class="card" style="margin-bottom:14px">
    <div style="display:flex;gap:14px;align-items:center">
      <div style="width:60px;height:60px;border-radius:30px;background:rgba(201,171,110,.14);display:flex;align-items:center;justify-content:center;font-size:28px">${m.icon}</div>
      <div>
        <div style="font-size:20px;font-weight:700">${r.name}</div>
        <div style="font-size:13px;color:var(--muted);margin-top:3px">${m.label}</div>
      </div>
    </div>
  </div>
  <div class="card" style="display:flex;margin-bottom:14px;text-align:center">
    <div style="flex:1;padding:12px"><div style="font-size:20px;font-weight:700;color:var(--gold)">${kcalPerServing}</div><div style="font-size:11px;color:var(--muted)">kcal</div></div>
    <div style="width:1px;background:var(--divider)"></div>
    <div style="flex:1;padding:12px"><div style="font-size:20px;font-weight:700">${r.servings}</div><div style="font-size:11px;color:var(--muted)">Portionen</div></div>
    <div style="width:1px;background:var(--divider)"></div>
    <div style="flex:1;padding:12px"><div style="font-size:20px;font-weight:700;color:var(--green)">${r.prepTimeMinutes}</div><div style="font-size:11px;color:var(--muted)">Min.</div></div>
  </div>`;
  if (r.ingredients?.length) {
    html += `<div class="card" style="margin-bottom:14px"><div class="card-title">Zutaten</div>`;
    r.ingredients.forEach(ing => {
      html += `<div style="display:flex;gap:8px;align-items:center;padding:7px 0;border-bottom:1px solid var(--divider)"><div style="width:6px;height:6px;border-radius:3px;background:var(--gold);flex-shrink:0"></div><span style="font-size:14px">${ing}</span></div>`;
    });
    html += `</div>`;
  }
  if (r.instructions) {
    html += `<div class="card" style="margin-bottom:14px"><div class="card-title">Zubereitung</div><p style="font-size:14px;line-height:1.7;color:var(--muted)">${r.instructions.replace(/\n/g,'<br>')}</p></div>`;
  }
  if (r.notes) {
    html += `<div class="card" style="margin-bottom:14px"><div class="card-title">Notizen</div><p style="font-size:14px;font-style:italic;color:var(--muted)">${r.notes}</p></div>`;
  }
  html += `<button onclick="deleteRecipe('${r.id}')" style="width:100%;padding:13px;background:rgba(191,77,64,.1);border:none;border-radius:12px;color:var(--red);font-size:15px;cursor:pointer">🗑 Rezept löschen</button>`;
  document.getElementById('modal-recipe-body').innerHTML = html;
  openModal('modal-recipe-detail');
}

function deleteRecipe(id) {
  if (!confirm('Rezept wirklich löschen?')) return;
  state.recipes = state.recipes.filter(r => r.id !== id);
  save();
  closeModal('modal-recipe-detail');
  renderRecipes();
}

// ═══════════════════════════════════════════════
// SHOPPING VIEW
// ═══════════════════════════════════════════════
function renderShopping() {
  const c = document.getElementById('shopping-content');
  if (!state.plan) {
    c.innerHTML = `<div class="empty-state"><div class="empty-icon">🛒</div><div class="empty-title">Noch kein Plan</div><div class="empty-text">Erstelle zuerst einen Essensplan, dann wird hier der Einkaufszettel automatisch generiert.</div></div>`;
    return;
  }
  if (!state.shopping?.length) {
    c.innerHTML = `<div class="empty-state">
      <div class="empty-icon">🛒</div>
      <div class="empty-title">Einkaufszettel erstellen</div>
      <div class="empty-text">Alle Zutaten aus deinem Plan werden automatisch zusammengestellt.</div>
      <button class="btn-gold" style="margin-top:8px;width:auto;padding:12px 28px" onclick="openShoppingFilter()">✨ Jetzt erstellen</button>
    </div>`;
    return;
  }
  const open    = state.shopping.filter(i => !i.checked);
  const checked = state.shopping.filter(i =>  i.checked);
  const total   = state.shopping.length;
  const done    = checked.length;
  const pct     = total ? (done/total*100).toFixed(1) : 0;

  let html = `
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
    <div style="font-size:22px;font-weight:700">Einkaufszettel</div>
    <button class="btn-ghost" onclick="openShoppingFilter()">↺ Neu</button>
  </div>
  <div class="card" style="margin-bottom:14px">
    <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--muted);margin-bottom:8px">
      <span>${done} von ${total} besorgt</span><span style="color:var(--gold);font-weight:600">${Math.round(pct)}%</span>
    </div>
    <div class="progress-track"><div class="progress-fill green" style="width:${pct}%"></div></div>
  </div>`;

  if (open.length) {
    html += `<div style="font-size:12px;font-weight:600;color:var(--muted);margin-bottom:8px">NOCH BESORGEN</div>
    <div class="card" style="padding:0;margin-bottom:14px">`;
    open.forEach(item => { html += shopRow(item); });
    html += `</div>`;
  }

  if (checked.length) {
    html += `<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <span style="font-size:12px;font-weight:600;color:var(--muted)">ERLEDIGT ✓</span>
      <button class="btn-danger" onclick="clearChecked()" style="font-size:12px">Löschen</button>
    </div>
    <div class="card section-faded" style="padding:0;margin-bottom:14px">`;
    checked.forEach(item => { html += shopRow(item); });
    html += `</div>`;
  }

  c.innerHTML = html;
}

function shopRow(item) {
  const dayLabel = item.days?.length === 1 ? `Tag ${item.days[0]}`
    : item.days?.length > 1 ? `Tag ${item.days[0]}–${item.days[item.days.length-1]}`
    : '';
  return `<div class="shop-row" onclick="toggleShopItem('${item.id}')">
    <div class="check-circle ${item.checked?'done':''}">${item.checked?'✓':''}</div>
    <div style="flex:1;min-width:0">
      <div class="shop-name ${item.checked?'done':''}">${item.name}</div>
      ${dayLabel ? `<div class="shop-days">📅 ${dayLabel}</div>` : ''}
    </div>
  </div>`;
}

function toggleShopItem(id) {
  const item = state.shopping.find(i => i.id === id);
  if (item) { item.checked = !item.checked; save(); renderShopping(); }
}

function clearChecked() {
  state.shopping = state.shopping.filter(i => !i.checked);
  save(); renderShopping();
}

function openShoppingFilter() {
  const total = state.plan?.days.length || 0;
  let html = `<p style="font-size:14px;color:var(--muted);margin-bottom:16px">Für wie viele Tage soll der Einkaufszettel erstellt werden?</p>
  <div class="card" style="padding:0">`;
  html += `<div class="shop-row" onclick="generateShopping(0)" style="font-size:15px">Alle ${total} Tage</div>`;
  for (let d = 1; d <= total; d++) {
    html += `<div class="shop-row" style="border-top:1px solid var(--divider);font-size:15px" onclick="generateShopping(${d})">Nächste ${d} ${d===1?'Tag':'Tage'}</div>`;
  }
  html += `</div>`;
  document.getElementById('modal-shopping-filter-body').innerHTML = html;
  openModal('modal-shopping-filter');
}

function generateShopping(days) {
  const plan = state.plan;
  if (!plan) return;
  const relevantDays = days === 0 ? plan.days : plan.days.slice(0, days);
  const map = {};
  for (const day of relevantDays) {
    for (const meal of day.meals) {
      for (const ing of (meal.ingredients || [])) {
        const key = ing.trim();
        if (!key) continue;
        if (!map[key]) map[key] = [];
        if (!map[key].includes(day.dayNumber)) map[key].push(day.dayNumber);
      }
    }
  }
  state.shopping = Object.entries(map).map(([name, days]) => ({
    id: crypto.randomUUID(), name, checked: false, days: days.sort((a,b)=>a-b)
  })).sort((a,b) => a.name.localeCompare(b.name, 'de'));
  save();
  closeModal('modal-shopping-filter');
  renderShopping();
}
</script>

<script>
// ═══════════════════════════════════════════════
// SETTINGS VIEW
// ═══════════════════════════════════════════════
function renderSettings() {
  const s = state.settings;
  const tokenVisible = window._tokenVisible || false;
  let html = `
  <!-- Ernaehrungsziele -->
  <div class="card">
    <div class="card-title">Ernährungsziele</div>
    <div class="field-row">
      <span>🔥 Kalorien / Tag</span>
      <span style="color:var(--gold);font-weight:600">${s.calories} kcal</span>
    </div>
    <input type="range" min="1200" max="4000" step="50" value="${s.calories}" oninput="updateCal(this.value)" style="width:100%;margin-bottom:14px">
    <div class="divider"></div>
    <div class="field-row">
      <span>🍴 Mahlzeiten / Tag</span>
      <div class="seg" style="width:130px">
        <button class="seg-btn ${s.mealsPerDay===2?'active':''}" onclick="setSetting('mealsPerDay',2)">2</button>
        <button class="seg-btn ${s.mealsPerDay===3?'active':''}" onclick="setSetting('mealsPerDay',3)">3</button>
        <button class="seg-btn ${s.mealsPerDay===4?'active':''}" onclick="setSetting('mealsPerDay',4)">4</button>
      </div>
    </div>
    <div class="divider"></div>
    <div class="field-row">
      <span>🌿 Ernährungsweise</span>
      <select onchange="setSetting('diet',this.value)" style="width:auto;padding:6px 10px">
        ${['Alles','Vegetarisch','Vegan','Pescetarisch'].map(d=>`<option ${s.diet===d?'selected':''}>${d}</option>`).join('')}
      </select>
    </div>
  </div>

  <!-- KI-Modell -->
  <div class="card">
    <div class="card-title">KI-Modell (Hugging Face)</div>
    <p style="font-size:12px;color:var(--muted);margin-bottom:12px">Alle Modelle sind über den kostenlosen Free-Tier verfügbar.</p>
    ${MODELS.map(m => `
    <div class="model-radio ${s.hfModel===m.id?'selected':''}" onclick="setSetting('hfModel','${m.id}')">
      <div class="radio-circle"><div class="radio-dot"></div></div>
      <div>
        <div style="font-size:14px">${m.name}</div>
        <div class="model-id">${m.id}</div>
      </div>
    </div>`).join('')}
  </div>

  <!-- HF Token -->
  <div class="card">
    <div class="card-title">Hugging Face Token</div>
    <p style="font-size:12px;color:var(--muted);margin-bottom:10px">
      Kostenlos auf <strong style="color:var(--gold)">huggingface.co</strong> → Settings → Access Tokens → Read Token erstellen.
    </p>
    <div class="token-row">
      <input type="${tokenVisible?'text':'password'}" id="token-input" placeholder="hf_..." value="${s.token}" oninput="setSetting('token',this.value)" autocapitalize="none" autocorrect="off">
      <button class="eye-btn" onclick="toggleTokenVis()">${tokenVisible?'🙈':'👁'}</button>
    </div>
    ${s.token ? `<div class="badge green" style="margin-top:8px;display:inline-flex">✓ Token gespeichert</div>` : ''}
  </div>

  <!-- Ungemochte Lebensmittel -->
  <div class="card">
    <div class="card-title">Ungemochte Lebensmittel</div>
    <p style="font-size:12px;color:var(--muted);margin-bottom:10px">Werden so selten wie möglich eingeplant.</p>
    <div class="tag-input-row">
      <input id="disliked-input" placeholder="z.B. Rosenkohl" onkeydown="if(event.key==='Enter'){addTag('disliked');event.preventDefault()}">
      <button class="tag-add" onclick="addTag('disliked')">＋</button>
    </div>
    <div class="tags">${(s.disliked||[]).map(t=>`<span class="tag bronze">${t}<button class="tag-x" onclick="removeTag('disliked','${t}')">✕</button></span>`).join('')}</div>
  </div>

  <!-- Allergien -->
  <div class="card">
    <div class="card-title">Zu vermeiden (Allergien)</div>
    <p style="font-size:12px;color:var(--muted);margin-bottom:10px">Werden strikt ausgeschlossen.</p>
    <div class="tag-input-row">
      <input id="avoided-input" placeholder="z.B. Gluten" onkeydown="if(event.key==='Enter'){addTag('avoided');event.preventDefault()}">
      <button class="tag-add" onclick="addTag('avoided')">＋</button>
    </div>
    <div class="tags">${(s.avoided||[]).map(t=>`<span class="tag red">${t}<button class="tag-x" onclick="removeTag('avoided','${t}')">✕</button></span>`).join('')}</div>
  </div>

  <!-- PWA Install Hint -->
  <div class="card" style="border:1px solid rgba(201,171,110,.2)">
    <div style="display:flex;gap:12px;align-items:flex-start">
      <div style="font-size:24px">📱</div>
      <div>
        <div style="font-size:14px;font-weight:600;margin-bottom:4px">Als App installieren</div>
        <div style="font-size:12px;color:var(--muted);line-height:1.6">
          In Safari auf dem iPhone: Teilen-Symbol tippen → <strong style="color:var(--text)">„Zum Home-Bildschirm"</strong> → Hinzufügen. Die App ist dann wie eine native App nutzbar.
        </div>
      </div>
    </div>
  </div>
  `;
  document.getElementById('settings-content').innerHTML = html;
}

function updateCal(val) {
  state.settings.calories = parseInt(val);
  document.querySelector('[oninput="updateCal(this.value)"]').nextElementSibling
    ? null : null;
  // Update display
  const rows = document.querySelectorAll('.field-row span');
  rows.forEach(s => { if (s.textContent.includes('kcal')) s.textContent = `${val} kcal`; });
  save();
}

function setSetting(key, val) {
  state.settings[key] = val;
  save();
  renderSettings();
}

function toggleTokenVis() {
  window._tokenVisible = !window._tokenVisible;
  renderSettings();
  // Re-focus token input
  setTimeout(() => document.getElementById('token-input')?.focus(), 50);
}

function addTag(type) {
  const input = document.getElementById(type + '-input');
  const val = input.value.trim();
  if (!val) return;
  if (!state.settings[type]) state.settings[type] = [];
  if (!state.settings[type].includes(val)) {
    state.settings[type].push(val);
    save();
    renderSettings();
  } else {
    input.value = '';
  }
}

function removeTag(type, val) {
  state.settings[type] = (state.settings[type] || []).filter(t => t !== val);
  save();
  renderSettings();
}

// ═══════════════════════════════════════════════
// HUGGING FACE API
// ═══════════════════════════════════════════════
async function generatePlan() {
  if (isGenerating) return;
  const token = state.settings.token.trim();
  if (!token) { alert('Bitte zuerst einen Hugging Face Token in den Einstellungen hinterlegen.'); return; }

  isGenerating = true;
  renderPlan();

  const season = currentSeason();
  const avoided  = state.settings.avoided?.length  ? state.settings.avoided.join(', ')  : 'keine';
  const disliked = state.settings.disliked?.length ? state.settings.disliked.join(', ') : 'keine';
  const mealNames = { 2:'Fruehstueck, Abendessen', 3:'Fruehstueck, Mittagessen, Abendessen', 4:'Fruehstueck, Mittagessen, Abendessen, Snack' }[state.settings.mealsPerDay] || '';
  const recipeList = state.recipes.length
    ? state.recipes.map(r => `- ID:${r.id} | ${r.name} (${(MEAL_META[r.category]||MEAL_META.any).label}, ${Math.round(r.calories/(r.servings||1))} kcal) | ${(r.ingredients||[]).slice(0,4).join(', ')}`).join('\n')
    : 'Keine.';

  const exampleJSON = '{"days":[{"dayNumber":1,"totalCalories":1950,"meals":[{"type":"breakfast","name":"Haferbrei","description":"Cremiger Haferbrei","calories":380,"ingredients":["80g Haferflocken","250ml Milch"],"nutritionHighlights":"Ballaststoffreich","isUserRecipe":false,"recipeId":null}]}]}';

  const prompt = `Erstelle einen ${state.numberOfDays}-Tage-Ernaehrungsplan.

EINSTELLUNGEN:
- Kalorienziel/Tag: ${state.settings.calories} kcal
- Ernaehrungsweise: ${state.settings.diet}
- Mahlzeiten/Tag: ${state.settings.mealsPerDay} (${mealNames})
- Strikt vermeiden: ${avoided}
- Ungemochte Lebensmittel: ${disliked}
- Jahreszeit: ${season}

LIEBLINGSREZEPTE:
${recipeList}

REGELN:
1. ${state.settings.calories} kcal/Tag einhalten (plus minus 10 Prozent)
2. Ausgewogene Makros: Protein, Kohlenhydrate, Fette, Ballaststoffe
3. Saisonale Lebensmittel fuer ${season} bevorzugen
4. Jede Mahlzeit nur einmal im gesamten Plan
5. Allergene/vermiedene Lebensmittel STRIKT ausschliessen
6. Lieblingsrezepte einbauen wenn passend (isUserRecipe: true)
7. Erstelle genau ${state.numberOfDays} Tage mit je ${state.settings.mealsPerDay} Mahlzeiten

Antworte NUR mit validem JSON (kein Text davor/danach):
${exampleJSON}

Erlaubte type-Werte: "breakfast","lunch","dinner","snack"`;

  try {
    const resp = await fetch('/api/hf', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        _token: token,          // wird vom Proxy-Server an HF weitergeleitet
        model: state.settings.hfModel,
        messages: [
          { role: 'system', content: 'Du bist ein Ernaehrungsberater. Antworte ausschliesslich mit validem JSON ohne Markdown.' },
          { role: 'user', content: prompt }
        ],
        max_tokens: 6000,
        temperature: 0.7,
        stream: false
      })
    });

    if (resp.status === 503) throw new Error('Modell lädt noch (Cold Start). Bitte ~30 Sekunden warten und erneut tippen.');
    if (!resp.ok) {
      const body = await resp.text();
      throw new Error(`API-Fehler ${resp.status}: ${body.slice(0,200)}`);
    }

    const data = await resp.json();
    const content = data.choices?.[0]?.message?.content || '';
    const jsonStr = extractJSON(content);
    const parsed = JSON.parse(jsonStr);

    // Add UUIDs to meals
    for (const day of parsed.days) {
      for (const meal of day.meals) {
        meal.id = crypto.randomUUID();
        if (meal.recipeId) {
          const linked = state.recipes.find(r => r.id === meal.recipeId);
          meal.linkedRecipeId = linked ? linked.id : null;
        }
      }
    }

    state.plan = { days: parsed.days, generatedAt: new Date().toISOString() };
    generateShopping(0); // Auto-generate shopping list
    save();

  } catch(e) {
    alert('Fehler: ' + e.message);
  }

  isGenerating = false;
  renderPlan();
}

function extractJSON(text) {
  let s = text;
  s = s.replace(/^```json\n?/, '').replace(/^```\n?/, '');
  s = s.replace(/\n?```$/, '');
  const start = s.indexOf('{');
  const end   = s.lastIndexOf('}');
  if (start !== -1 && end !== -1) return s.slice(start, end + 1);
  return s.trim();
}

function currentSeason() {
  const m = new Date().getMonth() + 1;
  if (m >= 3 && m <= 5)  return 'Fruehling';
  if (m >= 6 && m <= 8)  return 'Sommer';
  if (m >= 9 && m <= 11) return 'Herbst';
  return 'Winter';
}

// ═══════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════
load();
renderPlan();
</script>
</body>
</html>
␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀